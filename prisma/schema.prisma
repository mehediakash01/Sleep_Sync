// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String
  timezone            String               @default("UTC")
  nightlyTarget       Float                @default(7.5)
  bedtimeTarget       String               @default("22:45")
  streakGoal          Int                  @default(14)
  createdAt           DateTime             @default(now())
  sleepLogs           SleepLog[]
  notifications       Notification[]
  notificationSetting NotificationSetting?
}

model SleepLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  dateOfSession  DateTime
  timeInBed      DateTime
  wakeUpTime     DateTime
  sleepQuality   Int
  mood           String?
  caffeineIntake Boolean?
  alcoholIntake  Boolean?
  workout        Boolean?
  heavyMeal      Boolean?
  lateScreenTime Boolean?
  stressfulDay   Boolean?
  notes          String?
  duration       Float?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Comment {
  id         String   @id @default(cuid())
  blogId     String
  userId     String
  user       String
  userAvatar String?
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([blogId])
  @@index([userId])
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  blogId    String
  userId    String
  createdAt DateTime @default(now())

  @@unique([blogId, userId])
  @@index([blogId])
  @@map("likes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int
  type      String // SLEEP_LOGGED | STREAK | POOR_SLEEP | BEDTIME_REMINDER
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model NotificationSetting {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique
  emailEnabled    Boolean @default(true)
  bedtimeReminder Boolean @default(false)
  bedtimeHour     Int?
  bedtimeMinute   Int?
  poorSleepAlert  Boolean @default(true)
  streakAlert     Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_settings")
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  url       String   @unique
  content   String   @db.Text
  source    String
  status    String   @default("success")
  crawledAt DateTime @default(now()) @map("crawled_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([source])
  @@index([crawledAt])
  @@map("knowledge_articles")
}

model CrawlSource {
  id            String    @id @default(cuid())
  source        String    @unique
  lastCrawledAt DateTime? @map("last_crawled_at")
  lastJobId     String?   @map("last_job_id")
  lastStatus    String    @default("idle") @map("last_status")
  lastError     String?   @map("last_error") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([lastStatus])
  @@map("crawl_sources")
}
